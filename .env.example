# Copy to `.env.local` and fill values. After any schema change, run: npx prisma db push

# --- Step 2: Database (Neon PostgreSQL) ---
DATABASE_URL=

# --- Step 3: NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Root domain used for subdomain detection (production: reservezy.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# --- Step 7: Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=

# --- Step 11: Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Reservezy <bookings@yourdomain.com>

# --- Step 11: Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Step 13: Google OAuth (Sign-In + Calendar) ---
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Apple Sign-In ---
# 1. Enable "Sign In with Apple" in your Apple Developer account.
# 2. Create a Services ID (this becomes APPLE_ID).
# 3. Register your redirect URL: https://yourdomain.com/api/auth/callback/apple
# 4. Generate a private key (.p8) and note the Key ID and Team ID.
# 5. Generate APPLE_SECRET (a JWT) by running: node scripts/generate-apple-secret.js
APPLE_ID=com.example.yourapp
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Pre-generated JWT (valid up to 6 months). Regenerate before expiry.
APPLE_SECRET=

# --- Step 13: Microsoft Outlook ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# --- Step 14: Super admin (credentials auth) ---
SUPER_ADMIN_EMAIL=
# bcrypt hash for the super-admin password ($2a$...), generated server-side via bcryptjs.hash
SUPER_ADMIN_PASSWORD_HASH=

# --- Cron security (set in Vercel project settings) ---
CRON_SECRET=

# --- Optional: Logo uploads on Vercel ---
BLOB_READ_WRITE_TOKEN=
